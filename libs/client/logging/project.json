{
  "name": "client-logging",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/client/logging/src",
  "projectType": "library",
  "tags": ["type:util", "scope:client"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/client/logging",
        "main": "libs/client/logging/src/index.ts",
        "tsConfig": "libs/client/logging/tsconfig.lib.json",
        "assets": ["libs/client/logging/*.md"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "libs/client/logging"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/client/logging/**/*.ts"]
      }
    }
  }
}
