{
  "name": "client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/client/src",
  "tags": [
    "type:app",
    "scope:client"
  ],
  "targets": {
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "client:build",
        "dev": true
      },
      "configurations": {
        "development": {
          "buildTarget": "client:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "client:build:production",
          "dev": false
        }
      }
    },
    "build": {
      "executor": "@nx/next:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "{workspaceRoot}/dist/apps/client"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/client/.next"
        },
        "production": {}
      }
    },
    "start": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "production",
      "options": {
        "buildTarget": "client:build",
        "dev": false
      },
      "configurations": {
        "production": {
          "buildTarget": "client:build:production",
          "dev": false
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "apps/client"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/coverage"
      ],
      "options": {
        "command": "vitest run --coverage",
        "cwd": "apps/client"
      }
    },
    "test:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest --watch",
        "cwd": "apps/client"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "apps/client/**/*.{ts,tsx,js,jsx}"
        ]
      }
    }
  }
}