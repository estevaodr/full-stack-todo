{
  "name": "client-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/client-e2e/e2e",
  "implicitDependencies": ["client", "server"],
  "targets": {
    "e2e": {
      "executor": "@nx/playwright:playwright",
      "outputs": [
        "{workspaceRoot}/dist/.playwright/apps/client-e2e",
        "{workspaceRoot}/apps/client-e2e/playwright-report"
      ],
      "options": {
        "config": "apps/client-e2e/playwright.config.ts"
      }
    }
  }
}
