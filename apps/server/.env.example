# Copy to `.env` for local runs. See `specs/002-server-structured-logging/contracts/environment.md`.

# development | production | test (default: development)
NODE_ENV=development

# json | pretty | auto — empty/unset = auto. Invalid values fail startup. Transport shape needs process restart to apply.
LOG_FORMAT=auto

# fatal | error | warn | info | debug | trace (default: info). May change at runtime via process.env without restart (sync interval).
LOG_LEVEL=info

# Required for app (unchanged by logging feature)
# DATABASE_URL=postgresql://user:pass@host:5432/db
# JWT_SECRET=
